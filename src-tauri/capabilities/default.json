{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-stat",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://generativelanguage.googleapis.com/**"
        },
        {
          "url": "https://api.openai.com/**"
        },
        {
          "url": "https://ark.ap-southeast.bytepluses.com/**"
        }
      ]
    }
  ]
}